# ─── Data Mode ──────────────────────────────────────────────────
# local    — Mock data, no persistence (default)
# backend  — Next.js API + SQLite/JSON persistence
# contract — GenLayer studionet on-chain operations
NEXT_PUBLIC_LEXNET_DATA_MODE=backend

# ─── Database ──────────────────────────────────────────────────
# sqlite — Use Drizzle ORM with better-sqlite3 (recommended)
# json   — Legacy filesystem store (backward compat)
LEXNET_DB_MODE=sqlite

# ─── GenLayer Contract ──────────────────────────────────────────
# Deployed contract address on studionet
NEXT_PUBLIC_LEXNET_CONTRACT_ADDRESS=0x08a9897bbE5aEa24b41447f758FeD246035648B3

# GenLayer studionet RPC endpoint
NEXT_PUBLIC_GENLAYER_RPC_URL=https://studio.genlayer.com/api

# ─── Database Path (optional) ──────────────────────────────────
# LEXNET_DB_PATH=.lexnet-data/lexnet.db

# ─── Testnet Payments (optional) ───────────────────────────────
# LEXNET_ENABLE_TESTNET_PAYMENTS=false
